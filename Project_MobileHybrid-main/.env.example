# Frontend Environment Variables Template
# File location: Project_MobileHybrid-main/.env.example
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
# 3. Flutter reads these during build time
# 4. For production, update these before building

# API Configuration
API_BASE_URL=http://localhost:3000
API_TIMEOUT=30000

# App Configuration
APP_NAME=Go-Fit
APP_VERSION=1.0.0
DEBUG_MODE=false

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true

# Production API
PROD_API_URL=https://your-railway-backend.up.railway.app
